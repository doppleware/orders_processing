<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1720608007876-1" author="finkel">
        <createTable tableName="billing_entities">
            <column autoIncrement="true" name="id" type="INT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_billing_entities"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="1720608007876-2" author="finkel">
        <createTable tableName="billing_records">
            <column autoIncrement="true" name="id" type="INT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_billing_records"/>
            </column>
            <column name="entity_id" type="INT"/>
            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="order_id" type="INT"/>
        </createTable>
    </changeSet>
    <changeSet id="1720608007876-3" author="finkel">
        <createTable tableName="orders">
            <column autoIncrement="true" name="id" type="INT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_orders"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="1720608007876-4" author="finkel">
        <addForeignKeyConstraint baseColumnNames="entity_id" baseTableName="billing_records"
                                 constraintName="FK_BILLING_RECORDS_ON_ENTITY" referencedColumnNames="id"
                                 referencedTableName="billing_entities"/>
    </changeSet>
    <changeSet id="1720608007876-5" author="finkel">
        <addForeignKeyConstraint baseColumnNames="order_id" baseTableName="billing_records"
                                 constraintName="FK_BILLING_RECORDS_ON_ORDER" referencedColumnNames="id"
                                 referencedTableName="orders"/>
    </changeSet>

</databaseChangeLog>